<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <script>
  function getCsrfToken(){var m=document.querySelector('meta[name="csrf-token"]');if(m&&m.content)return m.content;var c=document.cookie.split('; ').find(function(c){return c.startsWith('csrf-token=')});return c?c.split('=')[1]:'';}
  function csrfFetch(u,o){o=o||{};o.headers=o.headers||{};o.headers['X-CSRF-Token']=getCsrfToken();return fetch(u,o);}
  </script>
  <title><%= typeof title !== 'undefined' ? title + ' – ' : '' %>PDF-Freigabe</title>
  <% if (typeof companyLogo !== 'undefined' && companyLogo) { %>
  <link rel="icon" type="image/png" href="/uploads/logo/<%= companyLogo %>">
  <% } else { %>
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
  <% } %>
  <link rel="stylesheet" href="/css/fonts.css?v=<%= typeof v !== 'undefined' ? v : '1' %>">
  <link rel="stylesheet" href="/css/style.css?v=<%= typeof v !== 'undefined' ? v : '1' %>">
</head>
<body>
  <% if (user) { %>
  <nav class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <% if (typeof companyLogo !== 'undefined' && companyLogo) { %>
      <div class="brand-icon" style="background:none;">
        <img src="/uploads/logo/<%= companyLogo %>" alt="" style="width:32px;height:32px;object-fit:contain;">
      </div>
      <% } else { %>
      <div class="brand-icon">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      </div>
      <% } %>
      <span class="brand-text">Freigabe</span>
    </div>
    <div class="sidebar-nav">
      <a href="/dashboard" class="nav-item <%= path === '/dashboard' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/jobs/create" class="nav-item <%= path === '/jobs/create' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        Neue Freigabe
      </a>
      <a href="/admin/customers" class="nav-item <%= path.startsWith('/admin/customer') ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Kunden
      </a>

      <% if (user.role === 'admin') { %>
      <div class="nav-divider">Verwaltung</div>
      <a href="/admin/users" class="nav-item <%= path.startsWith('/admin/users') ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Sachbearbeiter
      </a>
      <a href="/admin/statistics" class="nav-item <%= path.startsWith('/admin/statistics') ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Statistiken
      </a>
      <a href="/admin/audit" class="nav-item <%= path.startsWith('/admin/audit') ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Audit-Log
      </a>

      <!-- Einstellungen: aufklappbar -->
      <a href="/admin/job-templates" class="nav-item <%= path.startsWith('/admin/job-templates') ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        Job-Vorlagen
      </a>
      <a href="/admin/custom-fields" class="nav-item <%= path.startsWith('/admin/custom-fields') ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        Zusatzfelder
      </a>
      <%
        const settingsOpen = path.startsWith('/admin/settings') || path.startsWith('/admin/template') || path.startsWith('/webhooks') || path.startsWith('/admin/backup');
      %>
      <div class="nav-collapse <%= settingsOpen ? 'open' : '' %>">
        <a href="javascript:void(0)" class="nav-item <%= settingsOpen ? 'active' : '' %>" onclick="var p=this.parentElement;p.classList.toggle('open');var items=p.querySelector('.nav-collapse-items');items.style.display=p.classList.contains('open')?'block':'none';">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Einstellungen
          <svg style="margin-left:auto;opacity:0.5;transition:transform 0.2s;<%= settingsOpen ? 'transform:rotate(180deg);' : '' %>" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <div class="nav-collapse-items" style="<%= settingsOpen ? '' : 'display:none;' %>">
          <a href="/admin/settings" class="nav-item nav-sub <%= path === '/admin/settings' ? 'active' : '' %>">Allgemein</a>
          <a href="/admin/templates" class="nav-item nav-sub <%= path.startsWith('/admin/template') ? 'active' : '' %>">Mail-Vorlagen</a>
          <a href="/webhooks" class="nav-item nav-sub <%= path.startsWith('/webhooks') ? 'active' : '' %>">Webhooks</a>
          <a href="/admin/backup" class="nav-item nav-sub <%= path.startsWith('/admin/backup') ? 'active' : '' %>">Backup</a>
        </div>
      </div>
      <% } %>
    </div>

    <div class="sidebar-footer">
      <% if (user.role === 'admin') { %>
      <a href="/admin/sysinfo" class="nav-item <%= path.startsWith('/admin/sysinfo') ? 'active' : '' %>" style="margin-bottom:8px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        Systeminfo
      </a>
      <% } %>
      <a href="/notifications" class="nav-item notification-link <%= path === '/notifications' ? 'active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        Benachrichtigungen
        <% if (typeof notificationCount !== 'undefined' && notificationCount > 0) { %>
        <span class="notif-count-badge"><%= notificationCount > 9 ? '9+' : notificationCount %></span>
        <% } %>
      </a>

      <a href="/profile" class="user-badge" style="text-decoration:none;">
        <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <div class="user-info">
          <span class="user-name"><%= user.name %></span>
          <span class="user-role"><%= user.role === 'admin' ? 'Admin' : 'Bearbeiter' %></span>
        </div>
      </a>
      <a href="/logout" class="nav-item logout-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Abmelden
      </a>
    </div>
  </nav>
  <button class="mobile-toggle" id="mobileToggle" aria-label="Menü">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
  <% } %>

  <main class="<%= user ? 'has-sidebar' : '' %>">
    <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="toast toast-<%= flash.type %>" id="toast">
      <span><%= flash.text %></span>
      <button onclick="this.parentElement.remove()" class="toast-close">&times;</button>
    </div>
    <% } %>
