  </main>
  <script src="/js/app.js?v=<%= typeof v !== 'undefined' ? v : '1' %>"></script>
  <script>
  (function() {
    var isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    if (!isMobile) return;
    document.querySelectorAll('iframe.pdf-frame').forEach(function(iframe) {
      var src = iframe.src;
      var fallback = document.createElement('div');
      fallback.style.cssText = 'text-align:center;padding:32px 16px;background:var(--bg-alt);border-radius:var(--radius-lg);border:1px dashed var(--border);margin:4px 0;';
      fallback.innerHTML = '<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" style="margin-bottom:10px;display:block;margin-left:auto;margin-right:auto"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>'
        + '<p style="margin:0 0 14px;font-size:0.88rem;color:var(--text-muted)">PDF-Vorschau ist auf mobilen Geräten nicht verfügbar.</p>'
        + '<a href="' + src + '" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;padding:10px 22px;background:var(--accent);color:#fff;border-radius:var(--radius);font-weight:600;text-decoration:none;font-size:0.9rem;">'
        + '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>'
        + 'PDF öffnen</a>';
      iframe.style.display = 'none';
      iframe.parentNode.insertBefore(fallback, iframe.nextSibling);
    });
  })();
  </script>
</body>
</html>
