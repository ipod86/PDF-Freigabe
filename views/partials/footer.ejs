  </main>
  <script src="/js/app.js?v=<%= typeof v !== 'undefined' ? v : '1' %>"></script>
  <script>
  (function() {
    if (navigator.pdfViewerEnabled === true) return;
    var openIcon = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>';
    var btnStyle = 'display:inline-flex;align-items:center;gap:6px;padding:10px 22px;background:var(--accent);color:#fff;border-radius:var(--radius);font-weight:600;text-decoration:none;font-size:0.9rem;box-shadow:0 2px 8px rgba(0,0,0,0.25);';
    document.querySelectorAll('iframe.pdf-frame').forEach(function(iframe) {
      var previewUrl = iframe.src;
      var thumbUrl   = previewUrl.replace(/\/preview(\?.*)?$/, '/thumb');
      var wrapper    = document.createElement('div');
      wrapper.style.cssText = 'position:relative;border-radius:var(--radius-lg);overflow:hidden;background:var(--bg-alt);border:1px solid var(--border);margin:4px 0;';
      var img = document.createElement('img');
      img.src = thumbUrl;
      img.style.cssText = 'width:100%;display:block;max-height:520px;object-fit:contain;';
      var overlay = document.createElement('div');
      overlay.style.cssText = 'position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.18);';
      overlay.innerHTML = '<a href="' + previewUrl + '" target="_blank" rel="noopener" style="' + btnStyle + '">' + openIcon + 'PDF öffnen</a>';
      // Fallback falls kein Thumbnail vorhanden
      img.onerror = function() {
        wrapper.style.cssText = 'text-align:center;padding:32px 16px;background:var(--bg-alt);border-radius:var(--radius-lg);border:1px dashed var(--border);margin:4px 0;';
        wrapper.innerHTML = '<a href="' + previewUrl + '" target="_blank" rel="noopener" style="' + btnStyle + '">' + openIcon + 'PDF öffnen</a>';
      };
      wrapper.appendChild(img);
      wrapper.appendChild(overlay);
      iframe.style.display = 'none';
      iframe.parentNode.insertBefore(wrapper, iframe.nextSibling);
    });
  })();
  </script>
</body>
</html>
