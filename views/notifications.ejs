<%- include('partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">
      Benachrichtigungen
      <% if (unreadCount > 0) { %><span class="version-badge" style="font-size:0.8rem;"><%= unreadCount %> neu</span><% } %>
    </h1>
    <p class="page-subtitle">Ihre Benachrichtigungen der letzten 30 Tage</p>
  </div>
  <div class="header-actions">
    <% if (unreadCount > 0) { %>
    <button class="btn btn-ghost" id="markAllReadBtn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
      Alle gelesen &amp; löschen
    </button>
    <% } %>
    <a href="/dashboard" class="btn btn-ghost">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Zurück
    </a>
  </div>
</div>

<div class="notif-page-list">
  <% if (notifications.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    <p>Keine Benachrichtigungen vorhanden.</p>
  </div>
  <% } else { %>
    <% notifications.forEach(n => { %>
    <a href="<%= n.job_uuid ? '/jobs/' + n.job_uuid : '#' %>"
       class="notif-page-item <%= n.read ? '' : 'notif-page-unread' %>"
       data-id="<%= n.id %>">
      <div class="notif-page-icon notif-icon-<%= n.type %>">
        <%= n.type === 'approved' ? '✅' : n.type === 'rejected' ? '❌' : n.type === 'version' ? '📄' : n.type === 'reminder' ? '⏰' : '🔔' %>
      </div>
      <div class="notif-page-content">
        <strong><%= n.title %></strong>
        <% if (n.message) { %><p><%= n.message %></p><% } %>
        <small><%= new Date(n.created_at).toLocaleString('de-DE') %></small>
      </div>
      <% if (!n.read) { %>
      <span class="notif-unread-dot"></span>
      <% } %>
    </a>
    <% }) %>
  <% } %>
</div>

<style>
.notif-page-list { max-width:700px; }
.notif-page-item {
  display:flex; align-items:flex-start; gap:14px; padding:16px 20px;
  background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg);
  margin-bottom:8px; text-decoration:none; color:var(--text);
  transition:all 0.15s var(--ease); position:relative;
}
.notif-page-item:hover { border-color:var(--accent); box-shadow:var(--shadow); text-decoration:none; }
.notif-page-unread { background:var(--accent-soft); border-color:rgba(67,97,238,0.2); }
.notif-page-icon { width:40px; height:40px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; background:var(--bg); }
.notif-page-content { flex:1; min-width:0; }
.notif-page-content strong { display:block; font-size:0.92rem; margin-bottom:2px; }
.notif-page-content p { font-size:0.85rem; color:var(--text-secondary); margin:0; }
.notif-page-content small { font-size:0.78rem; color:var(--text-muted); }
.notif-unread-dot { width:8px; height:8px; border-radius:50%; background:var(--accent); flex-shrink:0; margin-top:6px; }
.notif-icon-approved { background:var(--green-bg); }
.notif-icon-rejected { background:var(--red-bg); }
.notif-icon-version { background:rgba(67,97,238,0.08); }
</style>

<script>
document.getElementById('markAllReadBtn')?.addEventListener('click', async () => {
  await csrfFetch('/api/notifications/read-all', { method:'POST' });
  location.reload();
});

document.querySelectorAll('.notif-page-item[data-id]').forEach(el => {
  el.addEventListener('click', () => {
    const id = el.dataset.id;
    if (id) csrfFetch('/api/notifications/read/' + id, { method:'POST' });
  });
});
</script>

<%- include('partials/footer') %>
