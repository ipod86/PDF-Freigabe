<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Statistiken</h1>
    <p class="page-subtitle">Auswertungen und Berichte</p>
  </div>
  <div class="header-actions">
    <a href="/api/export/csv" class="btn btn-ghost">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      CSV-Export (Alle)
    </a>
    <a href="/dashboard" class="btn btn-ghost">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Zurück
    </a>
  </div>
</div>

<!-- KPI-Karten -->
<div class="stats-grid stats-grid-5" id="kpiCards">
  <div class="stat-card">
    <div class="stat-number" id="kpiTotal">–</div>
    <div class="stat-label">Gesamt</div>
  </div>
  <div class="stat-card stat-approved">
    <div class="stat-number" id="kpiApproved">–</div>
    <div class="stat-label">Freigegeben</div>
  </div>
  <div class="stat-card stat-rejected">
    <div class="stat-number" id="kpiRejected">–</div>
    <div class="stat-label">Abgelehnt</div>
  </div>
  <div class="stat-card">
    <div class="stat-number" id="kpiAvgDays">–</div>
    <div class="stat-label">Ø Tage bis Rückmeldung</div>
  </div>
  <div class="stat-card">
    <div class="stat-number" id="kpiCorrectionRate">–</div>
    <div class="stat-label">Korrektur-Rate</div>
  </div>
</div>

<!-- Charts -->
<div class="charts-grid">
  <div class="chart-card">
    <h3>Freigaben pro Monat</h3>
    <canvas id="chartMonthly" height="280"></canvas>
  </div>
  <div class="chart-card">
    <h3>Top-Kunden</h3>
    <canvas id="chartCustomers" height="280"></canvas>
  </div>
</div>

<div class="charts-grid">
  <div class="chart-card">
    <h3>Sachbearbeiter-Übersicht</h3>
    <div id="creatorTable"></div>
  </div>
  <div class="chart-card">
    <h3>Schnellexport</h3>
    <div class="export-links">
      <a href="/api/export/csv" class="export-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <div>
          <strong>Alle Freigaben</strong>
          <span>Kompletter Export als CSV</span>
        </div>
      </a>
      <a href="/api/export/csv?status=pending" class="export-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div>
          <strong>Offene Freigaben</strong>
          <span>Nur ausstehende Jobs</span>
        </div>
      </a>
      <a href="/api/export/csv?status=approved" class="export-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <div>
          <strong>Freigegebene Jobs</strong>
          <span>Nur abgeschlossene</span>
        </div>
      </a>
      <a href="/api/export/csv?status=rejected" class="export-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        <div>
          <strong>Abgelehnte Jobs</strong>
          <span>Zur Nachbearbeitung</span>
        </div>
      </a>
    </div>
  </div>
</div>

<script src="/vendor/chart.umd.min.js?v=<%= typeof v !== 'undefined' ? v : '1' %>"></script>
<script>
const COLORS = {
  approved: '#10b981',
  rejected: '#ef4444',
  pending: '#f59e0b',
  total: '#4361ee',
};

async function loadStats() {
  try {
    const res = await fetch('/api/stats/detailed');
    const data = await res.json();

    // KPIs
    const basic = await (await fetch('/api/stats')).json();
    document.getElementById('kpiTotal').textContent = basic.total;
    document.getElementById('kpiApproved').textContent = basic.approved;
    document.getElementById('kpiRejected').textContent = basic.rejected;
    document.getElementById('kpiAvgDays').textContent = data.avgResponseDays ? data.avgResponseDays + ' d' : '–';

    if (data.versionStats && data.versionStats.total_jobs > 0) {
      const rate = Math.round((data.versionStats.corrected_jobs / data.versionStats.total_jobs) * 100);
      document.getElementById('kpiCorrectionRate').textContent = rate + '%';
    }

    // Monatschart
    if (data.monthly.length > 0) {
      const labels = data.monthly.map(m => {
        const [y, mo] = m.month.split('-');
        return new Date(y, mo - 1).toLocaleDateString('de-DE', { month: 'short', year: '2-digit' });
      });

      new Chart(document.getElementById('chartMonthly'), {
        type: 'bar',
        data: {
          labels,
          datasets: [
            { label: 'Freigegeben', data: data.monthly.map(m => m.approved), backgroundColor: COLORS.approved, borderRadius: 4 },
            { label: 'Abgelehnt',   data: data.monthly.map(m => m.rejected), backgroundColor: COLORS.rejected, borderRadius: 4 },
            { label: 'Offen',       data: data.monthly.map(m => m.pending),  backgroundColor: COLORS.pending,  borderRadius: 4 },
          ]
        },
        options: {
          responsive: true,
          plugins: { legend: { position: 'bottom' } },
          scales: { x: { stacked: true }, y: { stacked: true, beginAtZero: true, ticks: { stepSize: 1 } } }
        }
      });
    }

    // Kundenchart
    if (data.topCustomers.length > 0) {
      new Chart(document.getElementById('chartCustomers'), {
        type: 'bar',
        data: {
          labels: data.topCustomers.map(c => c.company.length > 20 ? c.company.slice(0, 20) + '…' : c.company),
          datasets: [
            { label: 'Freigegeben', data: data.topCustomers.map(c => c.approved), backgroundColor: COLORS.approved, borderRadius: 4 },
            { label: 'Abgelehnt',   data: data.topCustomers.map(c => c.rejected), backgroundColor: COLORS.rejected, borderRadius: 4 },
          ]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: { legend: { position: 'bottom' } },
          scales: { x: { stacked: true, beginAtZero: true, ticks: { stepSize: 1 } }, y: { stacked: true } }
        }
      });
    }

    // Sachbearbeiter-Tabelle
    if (data.byCreator.length > 0) {
      let html = '<table class="data-table compact-table"><thead><tr><th>Name</th><th>Gesamt</th><th>Freigegeben</th><th>Abgelehnt</th><th>Offen</th></tr></thead><tbody>';
      data.byCreator.forEach(c => {
        html += `<tr><td><strong>${c.name}</strong></td><td>${c.total}</td><td style="color:var(--green)">${c.approved}</td><td style="color:var(--red)">${c.rejected}</td><td style="color:var(--orange)">${c.pending}</td></tr>`;
      });
      html += '</tbody></table>';
      document.getElementById('creatorTable').innerHTML = html;
    }

  } catch (err) {
    console.error('Fehler beim Laden der Statistiken:', err);
  }
}

loadStats();
</script>

<style>
.stats-grid-5 { grid-template-columns: repeat(5, 1fr); }
.charts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 20px;
}
.chart-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: var(--shadow);
}
.chart-card h3 {
  font-size: 0.95rem;
  margin-bottom: 16px;
}
.compact-table td, .compact-table th { padding: 10px 14px; font-size: 0.85rem; }
.export-links { display: flex; flex-direction: column; gap: 10px; }
.export-link {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-decoration: none;
  color: var(--text);
  transition: all 0.15s var(--ease);
}
.export-link:hover { border-color: var(--accent); background: var(--accent-soft); text-decoration: none; }
.export-link strong { display: block; font-size: 0.88rem; }
.export-link span { display: block; font-size: 0.78rem; color: var(--text-muted); }
@media (max-width: 1024px) {
  .stats-grid-5 { grid-template-columns: repeat(3, 1fr); }
  .charts-grid { grid-template-columns: 1fr; }
}
@media (max-width: 768px) {
  .stats-grid-5 { grid-template-columns: 1fr 1fr; }
}
</style>

<%- include('../partials/footer') %>
