<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Webhooks</h1>
    <p class="page-subtitle">Externe Systeme bei Statusänderungen benachrichtigen</p>
  </div>
  <a href="/admin" class="btn btn-ghost">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Zurück
  </a>
</div>

<div class="info-box mb-lg">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
  <div>
    <strong>Webhook-Events:</strong>
    <code>created</code> (Neue Freigabe), <code>approved</code> (Freigegeben),
    <code>rejected</code> (Abgelehnt), <code>version</code> (Neue Version),
    <code>reminder</code> (Erinnerung gesendet), <code>all</code> (Alle Events).
    Payloads enthalten Job-Daten als JSON. Signiert mit HMAC-SHA256.
  </div>
</div>

<div class="card mb-lg">
  <h3>Neuen Webhook anlegen</h3>
  <form method="POST" action="/webhooks" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-row">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" required placeholder="z.B. Slack-Benachrichtigung">
      </div>
      <div class="form-group flex-2">
        <label>URL</label>
        <input type="url" name="url" required placeholder="https://hooks.slack.com/...">
      </div>
      <div class="form-group">
        <label>Events</label>
        <select name="events">
          <option value="all">Alle</option>
          <option value="approved,rejected">Freigabe/Ablehnung</option>
          <option value="created">Nur neue Freigaben</option>
          <option value="approved">Nur Freigaben</option>
          <option value="rejected">Nur Ablehnungen</option>
        </select>
      </div>
      <div class="form-group">
        <label>Methode</label>
        <select name="method">
          <option value="POST">POST (JSON-Body)</option>
          <option value="GET">GET (Query-Parameter)</option>
        </select>
      </div>
      <div class="form-group form-action">
        <button type="submit" class="btn btn-primary">Anlegen</button>
      </div>
    </div>
  </form>
</div>

<div class="table-wrap">
  <% if (hooks.length === 0) { %>
  <div class="empty-state"><p>Noch keine Webhooks konfiguriert.</p></div>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>URL</th>
        <th>Events</th>
        <th>Status</th>
        <th>Letzter Aufruf</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% hooks.forEach(h => { %>
      <tr class="<%= !h.active ? 'row-inactive' : '' %>">
        <td><strong><%= h.name %></strong></td>
        <td class="text-muted" style="max-width:250px;overflow:hidden;text-overflow:ellipsis;"><%= h.url %></td>
        <td><%= h.events %></td>
        <td>
          <% if (h.last_status === null) { %>
            <span class="status-badge badge-inactive">Nie</span>
          <% } else if (h.last_status >= 200 && h.last_status < 300) { %>
            <span class="status-badge badge-active"><%= h.last_status %></span>
          <% } else { %>
            <span class="status-badge" style="background:var(--red-bg);color:var(--red);"><%= h.last_status || 'Fehler' %></span>
          <% } %>
        </td>
        <td class="text-muted"><%= h.last_triggered ? new Date(h.last_triggered).toLocaleString('de-DE') : '–' %></td>
        <td class="col-actions">
          <form method="POST" action="/webhooks/<%= h.id %>/toggle" style="display:inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn-icon" title="<%= h.active ? 'Deaktivieren' : 'Aktivieren' %>">
              <% if (h.active) { %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <% } else { %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
              <% } %>
            </button>
          </form>
          <form method="POST" action="/webhooks/<%= h.id %>/delete" style="display:inline" onsubmit="return confirm('Webhook löschen?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn-icon btn-icon-danger" title="Löschen">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
