<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Sachbearbeiter</h1>
    <p class="page-subtitle">Team-Zugänge verwalten</p>
  </div>
</div>

<!-- Neuen Benutzer anlegen -->
<div class="card mb-lg">
  <h3>Neuen Sachbearbeiter anlegen</h3>
  <form method="POST" action="/admin/users" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-row">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" required placeholder="Max Mustermann">
      </div>
      <div class="form-group">
        <label>E-Mail</label>
        <input type="email" name="email" required placeholder="max@firma.de">
      </div>
      <div class="form-group">
        <label>Passwort</label>
        <input type="password" name="password" required placeholder="Sicheres Passwort">
      </div>
      <div class="form-group">
        <label>Rolle</label>
        <select name="role">
          <option value="user">Sachbearbeiter</option>
          <option value="admin">Administrator</option>
        </select>
      </div>
      <div class="form-group form-action">
        <button type="submit" class="btn btn-primary">Anlegen</button>
      </div>
    </div>
  </form>
</div>

<!-- Bestehende Benutzer -->
<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>E-Mail</th>
        <th>Rolle</th>
        <th>Status</th>
        <th>Erstellt</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
      <tr class="<%= !u.active ? 'row-inactive' : '' %>">
        <td><strong><%= u.name %></strong></td>
        <td><%= u.email %></td>
        <td><span class="role-badge role-<%= u.role %>"><%= u.role === 'admin' ? 'Admin' : 'Bearbeiter' %></span></td>
        <td><span class="status-badge <%= u.active ? 'badge-active' : 'badge-inactive' %>"><%= u.active ? 'Aktiv' : 'Inaktiv' %></span></td>
        <td class="text-muted"><%= new Date(u.created_at).toLocaleDateString('de-DE') %></td>
        <td class="col-actions">
          <button class="btn-icon" onclick="toggleEdit('user-<%= u.id %>')" title="Bearbeiten">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <% if (u.id !== user.id) { %>
          <form method="POST" action="/admin/users/<%= u.id %>/delete" style="display:inline" onsubmit="return confirm('Benutzer löschen?')">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn-icon btn-icon-danger" title="Löschen">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </form>
          <% } %>
        </td>
      </tr>
      <tr class="edit-row" id="user-<%= u.id %>" style="display:none">
        <td colspan="6">
          <form method="POST" action="/admin/users/<%= u.id %>/update" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-row">
              <div class="form-group"><label>Name</label><input type="text" name="name" value="<%= u.name %>" required></div>
              <div class="form-group"><label>E-Mail</label><input type="email" name="email" value="<%= u.email %>" required></div>
              <div class="form-group"><label>Neues Passwort</label><input type="password" name="password" placeholder="Leer = unverändert"></div>
              <div class="form-group">
                <label>Rolle</label>
                <select name="role">
                  <option value="user" <%= u.role==='user'?'selected':'' %>>Sachbearbeiter</option>
                  <option value="admin" <%= u.role==='admin'?'selected':'' %>>Administrator</option>
                </select>
              </div>
              <div class="form-group">
                <label class="checkbox-label"><input type="checkbox" name="active" <%= u.active ? 'checked' : '' %>> Aktiv</label>
              </div>
              <div class="form-group form-action">
                <button type="submit" class="btn btn-primary btn-sm">Speichern</button>
              </div>
            </div>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
function toggleEdit(id) {
  const row = document.getElementById(id);
  row.style.display = row.style.display === 'none' ? '' : 'none';
}
</script>

<%- include('../partials/footer') %>
