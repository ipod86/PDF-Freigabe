<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Systeminformationen</h1>
    <p class="page-subtitle">Server-Status, Versionen und Speicherplatz</p>
  </div>
</div>

<div class="sysinfo-grid">
  <!-- Server -->
  <div class="card">
    <h3>Server</h3>
    <dl class="info-list">
      <dt>Hostname</dt><dd><code><%= sysinfo.hostname %></code></dd>
      <dt>Betriebssystem</dt><dd><code><%= sysinfo.os %></code></dd>
      <dt>Architektur</dt><dd><code><%= sysinfo.arch %></code></dd>
      <dt>Uptime Server</dt><dd><%= sysinfo.uptime %></dd>
      <dt>Uptime App</dt><dd><%= sysinfo.appUptime %></dd>
    </dl>
  </div>

  <!-- Speicher -->
  <div class="card">
    <h3>Speicher</h3>
    <dl class="info-list">
      <dt>RAM gesamt</dt><dd><%= sysinfo.totalMem %></dd>
      <dt>RAM frei</dt><dd><%= sysinfo.freeMem %></dd>
      <dt>RAM App (Node.js)</dt><dd><%= sysinfo.appMem %></dd>
    </dl>
    <div class="meter-bar" style="margin-top:12px;">
      <div class="meter-fill" style="width:<%= sysinfo.memPercent %>%;background:<%= sysinfo.memPercent > 85 ? 'var(--red)' : sysinfo.memPercent > 60 ? 'var(--orange)' : 'var(--green)' %>;"></div>
    </div>
    <small class="text-muted"><%= sysinfo.memPercent %>% RAM belegt</small>
  </div>

  <!-- Festplatte -->
  <div class="card">
    <h3>Festplatte</h3>
    <dl class="info-list">
      <dt>Datenbank</dt><dd><%= sysinfo.dbSize %></dd>
      <dt>PDF-Uploads</dt><dd><%= sysinfo.uploadsSize %> (<%= sysinfo.uploadCount %> Dateien)</dd>
      <dt>Sessions</dt><dd><%= sysinfo.sessionsSize %></dd>
    </dl>
    <% if (sysinfo.diskFree) { %>
    <div class="meter-bar" style="margin-top:12px;">
      <div class="meter-fill" style="width:<%= sysinfo.diskPercent %>%;background:<%= sysinfo.diskPercent > 85 ? 'var(--red)' : sysinfo.diskPercent > 60 ? 'var(--orange)' : 'var(--green)' %>;"></div>
    </div>
    <small class="text-muted"><%= sysinfo.diskUsed %> / <%= sysinfo.diskTotal %> belegt (<%= sysinfo.diskPercent %>%)</small>
    <% } %>
  </div>

  <!-- Versionen -->
  <div class="card">
    <h3>Software-Versionen</h3>
    <dl class="info-list">
      <dt>Node.js</dt><dd><code><%= sysinfo.nodeVersion %></code></dd>
      <dt>npm</dt><dd><code><%= sysinfo.npmVersion %></code></dd>
      <dt>SQLite</dt><dd><code><%= sysinfo.sqliteVersion %></code></dd>
      <dt>Express</dt><dd><code><%= sysinfo.expressVersion %></code></dd>
      <dt>App-Version</dt><dd><code><%= sysinfo.appVersion %></code></dd>
    </dl>
  </div>

  <!-- Datenbank-Statistiken -->
  <div class="card">
    <h3>Datenbank</h3>
    <dl class="info-list">
      <dt>Benutzer</dt><dd><%= sysinfo.counts.users %></dd>
      <dt>Kunden</dt><dd><%= sysinfo.counts.customers %></dd>
      <dt>Ansprechpartner</dt><dd><%= sysinfo.counts.contacts %></dd>
      <dt>Freigaben</dt><dd><%= sysinfo.counts.jobs %></dd>
      <dt>PDF-Versionen</dt><dd><%= sysinfo.counts.versions %></dd>
      <dt>Audit-Einträge</dt><dd><%= sysinfo.counts.auditLogs %></dd>
    </dl>
  </div>

  <!-- Abhängigkeiten -->
  <div class="card">
    <h3 style="display:flex;align-items:center;justify-content:space-between;gap:8px">
      Node.js-Module
      <button class="btn btn-sm btn-outline" id="npm-outdated-btn" onclick="checkNpmOutdated()">Auf Updates prüfen</button>
    </h3>
    <div id="npm-outdated-result" style="margin-bottom:8px"></div>
    <div style="max-height:200px;overflow-y:auto;">
      <% sysinfo.deps.forEach(d => { %>
      <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid var(--border-light);font-size:0.82rem;">
        <span><%= d.name %></span>
        <code style="color:var(--text-muted);"><%= d.version %></code>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Update -->
  <div class="card" style="grid-column:1/-1">
    <h3>Software-Update</h3>
    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:12px">
      <span style="font-size:0.9rem">Installierte Version: <code><%= sysinfo.appVersion %></code></span>
      <span id="gh-version-badge" style="font-size:0.8rem;color:var(--text-muted)">Prüfe GitHub…</span>
      <button class="btn btn-sm btn-outline" onclick="checkGhVersion()">Versionscheck</button>
      <button class="btn btn-sm btn-primary" id="do-update-btn" onclick="doUpdate()">Update installieren</button>
    </div>
    <pre id="update-log-box" style="display:none;background:#1a1a1a;color:#ddd;padding:12px;border-radius:6px;font-size:11px;max-height:300px;overflow-y:auto;white-space:pre-wrap"></pre>
  </div>
</div>

<script>
async function checkGhVersion() {
  const badge = document.getElementById('gh-version-badge');
  badge.textContent = 'Prüfe…';
  try {
    const r = await fetch('/admin/latest-version');
    const d = await r.json();
    if (d.tag_name) {
      const current = 'v<%= sysinfo.appVersion %>';
      if (d.tag_name === current) {
        badge.textContent = `Aktuell (${d.tag_name})`;
        badge.style.color = 'var(--green)';
      } else {
        badge.textContent = `Neue Version: ${d.tag_name}`;
        badge.style.color = 'var(--orange)';
      }
    } else {
      badge.textContent = 'GitHub nicht erreichbar';
      badge.style.color = 'var(--text-muted)';
    }
  } catch(e) {
    badge.textContent = 'Fehler bei Prüfung';
  }
}

async function checkNpmOutdated() {
  const btn = document.getElementById('npm-outdated-btn');
  const box = document.getElementById('npm-outdated-result');
  btn.disabled = true; btn.textContent = 'Prüfe…';
  box.innerHTML = '<span style="font-size:12px;color:var(--text-muted)">npm outdated wird ausgeführt…</span>';
  try {
    const r = await fetch('/admin/npm-outdated');
    const d = await r.json();
    btn.disabled = false; btn.textContent = 'Auf Updates prüfen';
    if (!d.packages || d.packages.length === 0) {
      box.innerHTML = '<div style="font-size:12px;color:var(--green);padding:4px 0">Alle Pakete sind aktuell.</div>';
      return;
    }
    box.innerHTML = `<table style="width:100%;font-size:12px;border-collapse:collapse;margin-bottom:6px">
      <thead><tr style="text-align:left"><th style="padding:3px 8px">Paket</th><th>Installiert</th><th>Gewünscht</th><th style="color:var(--orange)">Neueste</th></tr></thead>
      <tbody>${d.packages.map(p => `<tr>
        <td style="padding:3px 8px"><code>${p.name}</code></td>
        <td>${p.current}</td><td>${p.wanted}</td>
        <td style="font-weight:600;color:var(--orange)">${p.latest}</td>
      </tr>`).join('')}</tbody>
    </table>`;
  } catch(e) {
    btn.disabled = false; btn.textContent = 'Auf Updates prüfen';
    box.innerHTML = `<span style="font-size:12px;color:var(--red)">Fehler: ${e.message}</span>`;
  }
}

async function doUpdate() {
  if (!confirm('Update installieren und App neu starten?')) return;
  const btn = document.getElementById('do-update-btn');
  const logBox = document.getElementById('update-log-box');
  btn.disabled = true;
  btn.textContent = '⏳ Herunterladen...';
  logBox.style.display = ''; logBox.textContent = '';

  const csrfToken = document.cookie.split('; ').find(r => r.startsWith('csrf-token='))?.split('=')[1] || '';
  try { await fetch('/admin/update', { method: 'POST', headers: { 'X-CSRF-Token': csrfToken } }); }
  catch(e) { logBox.textContent = 'Fehler: ' + e.message; btn.disabled = false; btn.textContent = 'Update installieren'; return; }

  let lastLog = '', serverGone = false;
  const steps = ['⏳ Herunterladen...','📦 Entpacken...','📁 Kopieren...','🔧 Abhängigkeiten...','🔄 Neustart...'];
  let stepIdx = 0;
  const stepIv = setInterval(() => { stepIdx = Math.min(stepIdx+1, steps.length-1); btn.textContent = steps[stepIdx]; }, 4000);

  const pollIv = setInterval(async () => {
    try {
      const d = await (await fetch('/admin/update-log')).json();
      if (d.log !== lastLog) { lastLog = d.log; logBox.textContent = d.log; logBox.scrollTop = logBox.scrollHeight; }
      if (d.log.includes('=== Update erfolgreich ===') && !serverGone) {
        serverGone = true; clearInterval(pollIv); clearInterval(stepIv);
        btn.textContent = '🔄 Neustart läuft...'; waitForRestart();
      }
    } catch(_) {
      if (!serverGone) { serverGone = true; clearInterval(pollIv); clearInterval(stepIv); btn.textContent = '🔄 Neustart läuft...'; waitForRestart(); }
    }
  }, 2000);

  function waitForRestart() {
    logBox.textContent = (lastLog||'') + '\n▸ Warte auf Neustart...';
    let tries = 0;
    const iv = setInterval(async () => {
      tries++;
      try {
        await fetch(window.location.origin + '/admin/latest-version');
        clearInterval(iv);
        btn.textContent = '✓ Update abgeschlossen';
        logBox.textContent = (lastLog||'') + '\n✓ Server läuft wieder.';
        alert('Update erfolgreich – Seite wird neu geladen.');
        window.location.reload();
      } catch(_) { if (tries > 60) { clearInterval(iv); btn.disabled = false; btn.textContent = 'Update installieren'; } }
    }, 2000);
  }
}

checkGhVersion();
</script>

<style>
.sysinfo-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.sysinfo-grid code { font-family:var(--font-mono); font-size:0.85rem; padding:1px 6px; background:var(--bg); border-radius:4px; }
.meter-bar { height:8px; background:var(--bg); border-radius:4px; overflow:hidden; }
.meter-fill { height:100%; border-radius:4px; transition:width 0.5s var(--ease); }
@media (max-width:768px) { .sysinfo-grid { grid-template-columns:1fr; } }
</style>

<%- include('../partials/footer') %>
