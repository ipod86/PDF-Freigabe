<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Ansprechpartner: <%= customer.company %></h1>
    <p class="page-subtitle">Kontakte für diese Firma verwalten</p>
  </div>
  <a href="/admin/customers" class="btn btn-ghost">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Zurück
  </a>
</div>

<div class="card mb-lg">
  <h3>Neuen Ansprechpartner anlegen</h3>
  <form method="POST" action="/admin/customers/<%= customer.id %>/contacts" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-row">
      <div class="form-group"><label>Name</label><input type="text" name="name" required placeholder="Anna Beispiel"></div>
      <div class="form-group"><label>E-Mail</label><input type="email" name="email" required placeholder="anna@firma.de"></div>
      <div class="form-group"><label>Telefon</label><input type="text" name="phone" placeholder="Optional"></div>
      <div class="form-group"><label>Position</label><input type="text" name="position" placeholder="Optional"></div>
      <div class="form-group form-action"><button type="submit" class="btn btn-primary">Anlegen</button></div>
    </div>
  </form>
</div>

<div class="table-wrap">
  <% if (contacts.length === 0) { %>
  <div class="empty-state"><p>Noch keine Ansprechpartner angelegt.</p></div>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr><th>Name</th><th>E-Mail</th><th>Telefon</th><th>Position</th><th>Status</th><th>Portal</th><th>Aktionen</th></tr>
    </thead>
    <tbody>
      <% contacts.forEach(c => { %>
      <tr class="<%= !c.active ? 'row-inactive' : '' %>">
        <td><strong><%= c.name %></strong></td>
        <td><%= c.email %></td>
        <td class="text-muted"><%= c.phone || '–' %></td>
        <td class="text-muted"><%= c.position || '–' %></td>
        <td><span class="status-badge <%= c.active ? 'badge-active' : 'badge-inactive' %>"><%= c.active ? 'Aktiv' : 'Inaktiv' %></span></td>
        <td>
          <% if (c.portal_id) { %>
            <span class="status-badge badge-active" title="Letzter Login: <%= c.portal_last_login || 'Noch nie' %>">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-1px;margin-right:3px"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Portal aktiv
            </span>
          <% } else { %>
            <span class="text-muted" style="font-size:0.8rem">–</span>
          <% } %>
        </td>
        <td class="col-actions">
          <button class="btn-icon" onclick="toggleEdit('co-<%= c.id %>')" title="Bearbeiten">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="btn-icon" onclick="togglePortal('portal-<%= c.id %>')" title="Portal-Zugang">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </button>
          <form method="POST" action="/admin/contacts/<%= c.id %>/delete" style="display:inline" onsubmit="return confirm('Ansprechpartner löschen?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn-icon btn-icon-danger" title="Löschen">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </form>
        </td>
      </tr>

      <%# Kontakt bearbeiten %>
      <tr class="edit-row" id="co-<%= c.id %>" style="display:none">
        <td colspan="7">
          <form method="POST" action="/admin/contacts/<%= c.id %>/update" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="customer_id" value="<%= customer.id %>">
            <div class="form-row">
              <div class="form-group"><label>Name</label><input type="text" name="name" value="<%= c.name %>" required></div>
              <div class="form-group"><label>E-Mail</label><input type="email" name="email" value="<%= c.email %>" required></div>
              <div class="form-group"><label>Telefon</label><input type="text" name="phone" value="<%= c.phone || '' %>"></div>
              <div class="form-group"><label>Position</label><input type="text" name="position" value="<%= c.position || '' %>"></div>
              <div class="form-group"><label class="checkbox-label"><input type="checkbox" name="active" <%= c.active ? 'checked' : '' %>> Aktiv</label></div>
              <div class="form-group form-action"><button type="submit" class="btn btn-primary btn-sm">Speichern</button></div>
            </div>
          </form>
        </td>
      </tr>

      <%# Portal-Zugang %>
      <tr class="edit-row" id="portal-<%= c.id %>" style="display:none">
        <td colspan="7">
          <% if (c.portal_id) { %>
            <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-start">
              <%# Portal bearbeiten %>
              <form method="POST" action="/admin/portal-users/<%= c.portal_id %>/update" class="inline-form" style="flex:1;min-width:300px">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <p style="margin:0 0 0.5rem;font-weight:600;font-size:0.85rem">Portal-Zugang bearbeiten</p>
                <div class="form-row">
                  <div class="form-group"><label>Name</label><input type="text" name="name" value="<%= c.portal_name %>" required></div>
                  <div class="form-group"><label>E-Mail</label><input type="email" name="email" value="<%= c.portal_email %>" required></div>
                  <div class="form-group form-action"><button type="submit" class="btn btn-primary btn-sm">Speichern</button></div>
                </div>
              </form>
              <%# Passwort zurücksetzen %>
              <form method="POST" action="/admin/portal-users/<%= c.portal_id %>/reset-password" class="inline-form" style="flex:1;min-width:260px">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <p style="margin:0 0 0.5rem;font-weight:600;font-size:0.85rem">Passwort zurücksetzen</p>
                <div class="form-row">
                  <div class="form-group"><label>Neues Passwort</label><input type="password" name="new_password" required placeholder="Neues Passwort"></div>
                  <div class="form-group form-action"><button type="submit" class="btn btn-sm" style="background:#f59e0b;color:#fff">Setzen</button></div>
                </div>
              </form>
              <%# Portal löschen %>
              <div style="display:flex;align-items:flex-end;padding-bottom:0.25rem">
                <form method="POST" action="/admin/portal-users/<%= c.portal_id %>/delete" onsubmit="return confirm('Portal-Zugang wirklich löschen?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-sm" style="background:#ef4444;color:#fff">Portal löschen</button>
                </form>
              </div>
            </div>
            <p style="margin:0.5rem 0 0;font-size:0.78rem;color:var(--text-muted)">Letzter Login: <%= c.portal_last_login || 'Noch nie' %></p>
          <% } else { %>
            <form method="POST" action="/admin/contacts/<%= c.id %>/portal-user" class="inline-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <p style="margin:0 0 0.5rem;font-weight:600;font-size:0.85rem">Portal-Zugang anlegen</p>
              <div class="form-row">
                <div class="form-group"><label>Name</label><input type="text" name="name" value="<%= c.name %>" required></div>
                <div class="form-group"><label>E-Mail</label><input type="email" name="email" value="<%= c.email %>" required></div>
                <div class="form-group"><label>Passwort</label><input type="password" name="password" required placeholder="Initialpasswort"></div>
                <div class="form-group form-action"><button type="submit" class="btn btn-primary btn-sm">Anlegen</button></div>
              </div>
            </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<script>
function toggleEdit(id) {
  const row = document.getElementById(id);
  row.style.display = row.style.display === 'none' ? '' : 'none';
}
function togglePortal(id) {
  const row = document.getElementById(id);
  row.style.display = row.style.display === 'none' ? '' : 'none';
}
</script>

<%- include('../partials/footer') %>
