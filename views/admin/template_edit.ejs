<style>
.placeholder-bar {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 14px 18px;
  margin-bottom: 20px;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: var(--shadow);
}
.placeholder-label { font-size: 0.78rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 8px; }
.placeholder-buttons { display: flex; flex-wrap: wrap; gap: 6px; }
.ph-btn {
  display: inline-flex; align-items: center; padding: 5px 12px;
  border: 1px solid var(--border); border-radius: 20px; background: var(--bg);
  font-family: var(--font); font-size: 0.78rem; font-weight: 600;
  color: var(--text-secondary); cursor: grab; transition: all 0.15s var(--ease);
  user-select: none;
}
.ph-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-soft); }
.ph-btn:active { cursor: grabbing; transform: scale(0.95); }
.ph-cond { border-style: dashed; color: var(--orange); }
.ph-cond:hover { border-color: var(--orange); background: var(--orange-bg); color: #92400e; }
.code-editor { font-family: var(--font-mono) !important; font-size: 0.82rem !important; tab-size: 2; line-height: 1.6; }
.template-preview { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; min-height: 200px; font-size: 0.9rem; }
.template-preview code { font-size: 0.82rem; }
</style>

<script>
// Aktiver Editor (der zuletzt fokussiert wurde)
let activeEditor = document.getElementById('body_html');

document.querySelectorAll('.editor-target').forEach(el => {
  el.addEventListener('focus', () => { activeEditor = el; });
});

// Klick → Platzhalter an Cursor-Position einfügen
document.querySelectorAll('.ph-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const ph = btn.dataset.ph;
    if (!activeEditor) return;
    const start = activeEditor.selectionStart;
    const end = activeEditor.selectionEnd;
    const text = activeEditor.value;

    if (ph.includes('...')) {
      // Bedingter Block: Text umschließen
      const selected = text.substring(start, end) || '...';
      const tag = ph.replace('...', selected);
      activeEditor.value = text.substring(0, start) + tag + text.substring(end);
    } else {
      activeEditor.value = text.substring(0, start) + ph + text.substring(end);
    }

    activeEditor.focus();
    const newPos = start + ph.length;
    activeEditor.setSelectionRange(newPos, newPos);
    updatePreview();
  });

  // Drag & Drop
  btn.setAttribute('draggable', 'true');
  btn.addEventListener('dragstart', (e) => {
    e.dataTransfer.setData('text/plain', btn.dataset.ph);
    e.dataTransfer.effectAllowed = 'copy';
  });
});

// Drop auf Textareas erlauben
document.querySelectorAll('.editor-target').forEach(el => {
  el.addEventListener('dragover', (e) => { e.preventDefault(); e.dataTransfer.dropEffect = 'copy'; });
  el.addEventListener('drop', (e) => {
    e.preventDefault();
    const ph = e.dataTransfer.getData('text/plain');
    const start = el.selectionStart;
    el.value = el.value.substring(0, start) + ph + el.value.substring(start);
    el.focus();
    updatePreview();
  });
});

// Vorschau
const htmlEditor = document.getElementById('body_html');
const preview = document.getElementById('preview');

function updatePreview() {
  let html = htmlEditor.value;
  const demoVars = {
    contact_name: 'Anna Müller', job_name: 'Visitenkarten Sommer 2025',
    description: 'Bitte auf Sonderfarbe HKS 43 achten', approval_link: '#',
    job_link: '#', creator_name: 'Max Sachbearbeiter', creator_email: 'max@firma.de',
    customer_company: 'Beispiel GmbH', customer_comment: 'Sieht gut aus!',
    status_text: 'Freigegeben', company_name: 'Druckerei Mustermann',
    due_date: '25.03.2026',
    access_password: 'Geheim123',
    privacy_link: '/datenschutz',
    imprint_link: '/impressum'
  };
  for (const [k,v] of Object.entries(demoVars)) html = html.replace(new RegExp('\\{\\{' + k + '\\}\\}', 'g'), v);
  html = html.replace(/\{\{#if\s+\w+\}\}/g, '').replace(/\{\{\/if\}\}/g, '');
  preview.innerHTML = html;
}

htmlEditor.addEventListener('input', updatePreview);
updatePreview();
</script>

<%- include('../partials/footer') %>
