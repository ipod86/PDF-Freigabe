<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title"><%= template.name %></h1>
    <p class="page-subtitle"><%= template.description || 'Mail-Vorlage bearbeiten' %></p>
  </div>
  <a href="/admin/templates" class="btn btn-ghost">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Zurück
  </a>
</div>

<!-- Platzhalter-Leiste -->
<div class="placeholder-bar">
  <span class="placeholder-label">Platzhalter einfügen:</span>
  <div class="placeholder-buttons">
    <button type="button" class="ph-btn" data-ph="{{contact_name}}" title="Name des Ansprechpartners">Ansprechpartner</button>
    <button type="button" class="ph-btn" data-ph="{{job_name}}" title="Name des Auftrags">Auftragsname</button>
    <button type="button" class="ph-btn" data-ph="{{description}}" title="Besonderheiten/Hinweis">Besonderheiten</button>
    <button type="button" class="ph-btn" data-ph="{{approval_link}}" title="Link zur Kunden-Freigabeseite">Freigabe-Link</button>
    <button type="button" class="ph-btn" data-ph="{{job_link}}" title="Link zur internen Detailseite">Job-Link (intern)</button>
    <button type="button" class="ph-btn" data-ph="{{creator_name}}" title="Name des Sachbearbeiters">Sachbearbeiter</button>
    <button type="button" class="ph-btn" data-ph="{{creator_email}}" title="E-Mail des Sachbearbeiters">Sachbearbeiter-Mail</button>
    <button type="button" class="ph-btn" data-ph="{{customer_company}}" title="Firmenname des Kunden">Firma</button>
    <button type="button" class="ph-btn" data-ph="{{customer_comment}}" title="Kommentar des Kunden bei Freigabe/Ablehnung">Kunden-Kommentar</button>
    <button type="button" class="ph-btn" data-ph="{{status_text}}" title="Freigegeben / Abgelehnt">Status-Text</button>
    <button type="button" class="ph-btn" data-ph="{{company_name}}" title="Ihr Firmenname (aus Einstellungen)">Eigene Firma</button>
    <button type="button" class="ph-btn" data-ph="{{due_date}}" title="Fälligkeitsdatum der Freigabe">Fällig bis</button>
    <button type="button" class="ph-btn" data-ph="{{access_password}}" title="Passwort für die Freigabe (falls gesetzt)">Passwort</button>
    <button type="button" class="ph-btn" data-ph="{{privacy_link}}" title="Link zur Datenschutzerklärung (automatisch im Footer)">Datenschutz-Link</button>
    <button type="button" class="ph-btn" data-ph="{{imprint_link}}" title="Link zum Impressum (automatisch im Footer)">Impressum-Link</button>
    <button type="button" class="ph-btn ph-cond" data-ph="{{#if description}}...{{/if}}" title="Block nur anzeigen wenn Besonderheiten vorhanden">Wenn Besonderheiten</button>
    <button type="button" class="ph-btn ph-cond" data-ph="{{#if customer_comment}}...{{/if}}" title="Block nur anzeigen wenn Kunden-Kommentar vorhanden">Wenn Kommentar</button>
    <button type="button" class="ph-btn ph-cond" data-ph="{{#if due_date}}...{{/if}}" title="Block nur anzeigen wenn Fälligkeitsdatum gesetzt">Wenn Fällig</button>
    <button type="button" class="ph-btn ph-cond" data-ph="{{#if access_password}}...{{/if}}" title="Block nur anzeigen wenn Passwort gesetzt">Wenn Passwort</button>
  </div>
</div>

<form method="POST" action="/admin/templates/<%= template.id %>" class="template-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="form-row-3" style="margin-bottom:16px;">
    <div class="form-group">
      <label for="tpl_name">Vorlagenname</label>
      <input type="text" id="tpl_name" name="name" value="<%= template.name %>" required>
    </div>
    <div class="form-group">
      <label for="tpl_event">Auslöser (Ereignis)</label>
      <select name="event" id="tpl_event">
        <option value="approval_created" <%= template.event === 'approval_created' ? 'selected' : '' %>>Freigabe erstellt</option>
        <option value="approval_approved" <%= template.event === 'approval_approved' ? 'selected' : '' %>>Freigabe erteilt</option>
        <option value="approval_rejected" <%= template.event === 'approval_rejected' ? 'selected' : '' %>>Freigabe abgelehnt</option>
        <option value="customer_confirmation" <%= template.event === 'customer_confirmation' ? 'selected' : '' %>>Kunden-Bestätigung</option>
        <option value="reminder" <%= template.event === 'reminder' ? 'selected' : '' %>>Erinnerung</option>
        <option value="version_uploaded" <%= template.event === 'version_uploaded' ? 'selected' : '' %>>Neue Version</option>
        <option value="manual" <%= template.event === 'manual' ? 'selected' : '' %>>Manuell</option>
      </select>
    </div>
    <div class="form-group">
      <label for="tpl_recipient">Empfänger</label>
      <select name="recipient" id="tpl_recipient">
        <option value="customer" <%= template.recipient === 'customer' ? 'selected' : '' %>>Kunde</option>
        <option value="creator" <%= template.recipient === 'creator' ? 'selected' : '' %>>Sachbearbeiter</option>
        <option value="both" <%= template.recipient === 'both' ? 'selected' : '' %>>Beide</option>
      </select>
    </div>
  </div>

  <div class="form-group">
    <label for="tpl_desc">Beschreibung</label>
    <input type="text" id="tpl_desc" name="description" value="<%= template.description || '' %>" placeholder="Wann wird diese Vorlage verwendet?">
  </div>

  <div class="form-group">
    <label for="subject">Betreff</label>
    <input type="text" id="subject" name="subject" value="<%= template.subject %>" required class="editor-target">
  </div>

  <div class="form-group">
    <label for="body_html">HTML-Inhalt</label>
    <textarea id="body_html" name="body_html" rows="18" class="code-editor editor-target"><%= template.body_html %></textarea>
  </div>

  <div class="form-group">
    <label for="body_text">Text-Inhalt (Fallback ohne HTML)</label>
    <textarea id="body_text" name="body_text" rows="10" class="code-editor editor-target"><%= template.body_text %></textarea>
  </div>

  <div class="form-group">
    <label>Vorschau <small class="text-muted">(mit Beispieldaten)</small></label>
    <div class="template-preview" id="preview"></div>
  </div>

  <div class="form-actions">
    <a href="/admin/templates" class="btn btn-ghost">Abbrechen</a>
    <button type="submit" class="btn btn-primary">Vorlage speichern</button>
  </div>
</form>

