<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Kundenstamm</h1>
    <p class="page-subtitle">Firmen und Ansprechpartner verwalten</p>
  </div>
</div>

<div class="card mb-lg">
  <h3>Neuen Kunden anlegen</h3>
  <form method="POST" action="/admin/customers" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-row">
      <div class="form-group flex-2">
        <label>Firma</label>
        <input type="text" name="company" required placeholder="Firmenname GmbH">
      </div>
      <div class="form-group flex-2">
        <label>Notizen</label>
        <input type="text" name="notes" placeholder="Optional: Kundennummer, Hinweise...">
      </div>
      <div class="form-group form-action">
        <button type="submit" class="btn btn-primary">Anlegen</button>
      </div>
    </div>
  </form>
</div>

<div class="table-wrap">
  <% if (customers.length === 0) { %>
  <div class="empty-state">
    <p>Noch keine Kunden angelegt.</p>
  </div>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Firma</th>
        <th>Ansprechpartner</th>
        <th>Jobs</th>
        <th>Notizen</th>
        <th>Status</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% customers.forEach(c => { %>
      <tr class="<%= !c.active ? 'row-inactive' : '' %>">
        <td><strong><%= c.company %></strong></td>
        <td><%= c.contact_count %></td>
        <td><%= c.job_count %></td>
        <td class="text-muted"><%= c.notes || '–' %></td>
        <td><span class="status-badge <%= c.active ? 'badge-active' : 'badge-inactive' %>"><%= c.active ? 'Aktiv' : 'Inaktiv' %></span></td>
        <td class="col-actions">
          <a href="/admin/customers/<%= c.id %>/contacts" class="btn-icon" title="Ansprechpartner">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </a>
          <button class="btn-icon" onclick="togglePortal('portal-<%= c.id %>')" title="Portal-Zugang">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </button>
          <button class="btn-icon" onclick="toggleEdit('cust-<%= c.id %>')" title="Bearbeiten">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <form method="POST" action="/admin/customers/<%= c.id %>/delete" style="display:inline" onsubmit="return confirm('Kunde &quot;<%= c.company %>&quot; wirklich löschen?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn-icon btn-icon-danger" title="Löschen">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </form>
        </td>
      </tr>
      <tr class="edit-row" id="cust-<%= c.id %>" style="display:none">
        <td colspan="6">
          <form method="POST" action="/admin/customers/<%= c.id %>/update" class="inline-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-row">
              <div class="form-group flex-2"><label>Firma</label><input type="text" name="company" value="<%= c.company %>" required></div>
              <div class="form-group flex-2"><label>Notizen</label><input type="text" name="notes" value="<%= c.notes || '' %>"></div>
              <div class="form-group"><label class="checkbox-label"><input type="checkbox" name="active" <%= c.active ? 'checked' : '' %>> Aktiv</label></div>
              <div class="form-group form-action"><button type="submit" class="btn btn-primary btn-sm">Speichern</button></div>
            </div>
          </form>
        </td>
      </tr>
      <tr class="edit-row" id="portal-<%= c.id %>" style="display:none">
        <td colspan="6">
          <div style="padding:12px;background:var(--bg-alt);border-radius:var(--radius);">
            <h4 style="margin:0 0 10px;font-size:0.9rem;">Portal-Benutzer anlegen für <%= c.company %></h4>
            <form method="POST" action="/admin/customers/<%= c.id %>/portal-user" class="inline-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="form-row">
                <div class="form-group flex-2"><label>Name</label><input type="text" name="name" required placeholder="Max Mustermann"></div>
                <div class="form-group flex-2"><label>E-Mail</label><input type="email" name="email" required placeholder="kunde@firma.de"></div>
                <div class="form-group flex-2"><label>Passwort</label><input type="password" name="password" required placeholder="Mindestens 8 Zeichen"></div>
                <div class="form-group form-action"><button type="submit" class="btn btn-primary btn-sm">Anlegen</button></div>
              </div>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<script>
function toggleEdit(id) {
  const row = document.getElementById(id);
  row.style.display = row.style.display === 'none' ? '' : 'none';
}
function togglePortal(id) {
  const row = document.getElementById(id);
  row.style.display = row.style.display === 'none' ? '' : 'none';
}
</script>

<%- include('../partials/footer') %>
