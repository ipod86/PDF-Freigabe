<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <% if (typeof companyLogo !== 'undefined' && companyLogo) { %><link rel="icon" href="/uploads/logo/<%= companyLogo %>"><% } else { %><link rel="icon" type="image/svg+xml" href="/img/favicon.svg"><% } %>
  <link rel="stylesheet" href="/css/fonts.css?v=<%= typeof v !== 'undefined' ? v : '1' %>">
  <link rel="stylesheet" href="/css/style.css?v=<%= typeof v !== 'undefined' ? v : '1' %>">
  <link rel="stylesheet" href="/css/approve.css?v=<%= typeof v !== 'undefined' ? v : '1' %>">
</head>
<body class="approve-body">
  <header class="approve-header">
    <div class="approve-brand">
      <% if (typeof companyLogo !== 'undefined' && companyLogo) { %>
      <img src="/uploads/logo/<%= companyLogo %>" alt="<%= companyName %>" style="max-height:28px;">
      <% } else { %>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <% } %>
      <span><%= companyName %></span>
    </div>
  </header>

  <main class="approve-main">
    <div class="password-gate">
      <div class="gate-icon">
        <% if (typeof companyLogo !== 'undefined' && companyLogo) { %>
        <img src="/uploads/logo/<%= companyLogo %>" alt="" style="width:48px;height:48px;object-fit:contain;">
        <% } else { %>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        <% } %>
      </div>
      <h2>Passwortgeschützt</h2>
      <p>Die Freigabe für <strong><%= jobName %></strong> ist passwortgeschützt. Bitte geben Sie das Passwort ein, das Sie von Ihrem Ansprechpartner erhalten haben.</p>

      <% if (error) { %>
      <div class="gate-error">Falsches Passwort. Bitte versuchen Sie es erneut.</div>
      <% } %>

      <form method="POST" action="/approve/<%= token %>/auth" class="gate-form">
        <div class="form-group">
          <input type="password" name="password" required autofocus placeholder="Passwort eingeben" class="gate-input">
        </div>
        <button type="submit" class="btn btn-primary btn-full">Zugang freischalten</button>
      </form>
    </div>
  </main>

  <footer class="approve-footer">
    <p>Powered by PDF-Freigabe &middot; <%= companyName %> &middot; <a href="/impressum" style="color:inherit;text-decoration:underline;">Impressum</a> &middot; <a href="/datenschutz" style="color:inherit;text-decoration:underline;">Datenschutz</a></p>
  </footer>
</body>
</html>

<style>
.password-gate {
  max-width: 440px;
  margin: 0 auto;
  background: #fff;
  border-radius: 12px;
  padding: 48px 36px;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}
.gate-icon { color: var(--accent); margin-bottom: 16px; }
.password-gate h2 { font-size: 1.3rem; margin-bottom: 8px; }
.password-gate p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 24px; line-height: 1.5; }
.gate-error {
  background: var(--red-bg);
  color: #991b1b;
  border: 1px solid var(--red-border);
  padding: 10px 16px;
  border-radius: 8px;
  font-size: 0.88rem;
  margin-bottom: 16px;
}
.gate-form { text-align: left; }
.gate-input {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 1rem;
  font-family: var(--font);
  text-align: center;
  letter-spacing: 2px;
}
.gate-input:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-soft);
}
</style>
